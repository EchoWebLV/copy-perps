{
  "name": "breach",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS=\"$NODE_OPTIONS --require ./scripts/suppress-known-warnings.cjs\" next build && npm run build:standalone-assets",
    "build:standalone-assets": "rm -rf .next/standalone/public .next/standalone/.next/static && mkdir -p .next/standalone/.next && cp -R public .next/standalone/public && cp -R .next/static .next/standalone/.next/static",
    "start": "HOSTNAME=0.0.0.0 node .next/standalone/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:apply:portfolio-snapshots": "tsx scripts/apply-portfolio-snapshots.ts",
    "db:studio": "drizzle-kit studio",
    "seed:bots": "tsx --env-file=.env.local scripts/seed-bots.ts",
    "refresh:ostium": "tsx --env-file=.env.local scripts/refresh-ostium.ts",
    "arena:crank": "tsx scripts/arena/crank-worker.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@neondatabase/serverless": "^1.1.0",
    "@noble/ed25519": "^3.1.0",
    "@privy-io/react-auth": "^3.23.1",
    "@privy-io/server-auth": "^1.32.5",
    "@solana/kit": "^5.5.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "botid": "^1.5.11",
    "bs58": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "flash-sdk": "^15.16.14",
    "lucide-react": "^0.460.0",
    "next": "^16.0.0",
    "postgres": "^3.4.9",
    "posthog-js": "^1.372.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.21.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@solana/web3.js": "^1.98.4"
  }
}
