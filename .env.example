# --- Phase 1+ keys (not required for Phase 0 mock UI) ---

# Privy (auth + Solana embedded wallet)
# Fiat onramp (Buy USDC with card) is enabled in the Privy Dashboard, NOT via env vars:
#   dashboard.privy.io → App → Wallet infrastructure → Funding
#   1) Toggle "Fund with card" ON
#   2) Enable MoonPay as a card provider (Coinbase Onramp optional fallback)
#   3) For branded UX + rev share, link a MoonPay partner account
#      (moonpay.com/business). Otherwise Privy's default MoonPay integration is used.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Privy TEE server-side signing. Signer and policy IDs are public-safe.
NEXT_PUBLIC_PRIVY_FLASH_SIGNER_ID=
NEXT_PUBLIC_PRIVY_FLASH_POLICY_IDS=
PRIVY_WALLET_AUTHORIZATION_PRIVATE_KEY=

# Solana RPC (Helius)
NEXT_PUBLIC_HELIUS_RPC_URL=
HELIUS_API_KEY=

# Meme trending data
# Primary: DexScreener (no key needed) — https://api.dexscreener.com
# Fallback / supplement: Solana Tracker, GeckoTerminal — also no key needed for free tier
# Smart-money tracking comes from Helius (above) — same key

# Jupiter (no key needed for public endpoints)
# JUPITER_API_BASE=https://lite-api.jup.ag

# Hyperliquid (no key needed for public REST/WS)

# Database (Neon Postgres via Vercel Marketplace)
DATABASE_URL=

# Cache (Upstash Redis via Vercel Marketplace)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cron auth — Vercel cron sends `Authorization: Bearer ${CRON_SECRET}` automatically
# when this env var is set in the Vercel project. Use a strong random value in prod.
CRON_SECRET=

# Sentry (optional)
SENTRY_DSN=

# PostHog (product analytics + session replay). Reverse-proxied through
# /ingest in next.config.ts so ad blockers don't eat events. Get the key
# from app.posthog.com → Project settings → Project API key.
NEXT_PUBLIC_POSTHOG_KEY=

# Privy gas sponsorship is configured in the Privy Dashboard, not env vars:
#   dashboard.privy.io -> Gas sponsorship
# Pacifica tail deposits use Privy's sponsored Solana sign-and-send path.

# Legacy rails only. The current whale/Pacifica tail flow does not use the
# server fee-payer Gas Wallet path.
FEATURE_GASLESS_BETS=
GAS_WALLET_PRIVATE_KEY=

# Treasury Wallet — legacy rails fee receiver.
TREASURY_PUBKEY=

# --- Phase 1 pivot ---
# When unset or "false", legacy rails (meme / prediction / perp) return 410
# on all routes and are hidden from the feed. Default off.
FEATURE_LEGACY_RAILS=false

# Phoenix Eternal referral code (optional in Phase 1; used when their tx
# builder accepts a referrer parameter). Leave blank if not yet onboarded.
PHOENIX_REFERRAL_CODE=

# Agent wallet master encryption key (base64-encoded 32 bytes, AES-256-GCM).
# Generate with: openssl rand -base64 32
# Rotating this key invalidates ALL existing agent_wallets rows; rotate only
# alongside a re-bind migration.
AGENT_WALLET_ENCRYPTION_KEY=

# --- Phase 1 (paper AI bots) ---
# When unset or "false", the wallet-leaderboard copy-trade rail returns 410
# on all routes and is hidden from the feed. Default off. Paper AI bots are
# the active rail.
FEATURE_COPY_TRADE=false

# Whale copy-trading social platform is the default app. Set to "false"
# only when intentionally booting the legacy paper-bot arena.
FEATURE_WHALE_SOCIAL=true

# Reserved for casino-mode work (parked). Default off.
FEATURE_CASINO_MODE=false

# --- On-chain bot arena (devnet ER) ---
ARENA_PROGRAM_ID=
ARENA_ER_ENDPOINT=https://devnet.magicblock.app
ARENA_MARKET_ID=0                    # u8 market PDA seed; 1 = live successor after the 2026-06-12 wedge
ARENA_ADMIN_KEYPAIR=
ARENA_CRANK_KEYPAIR=
ARENA_CRANK_INTERVAL_MS=2000
ARENA_COMMIT_INTERVAL_MS=300000
DISABLE_ARENA_CRANK=

# On-chain bot arena UI (Phase 2) — client-visible; chain is the only source.
NEXT_PUBLIC_ARENA_PROGRAM_ID=        # deployed arena program (empty = arena page shows offline state)
NEXT_PUBLIC_ARENA_ER_ENDPOINT=https://devnet.magicblock.app
NEXT_PUBLIC_ARENA_BOTS=scalper-v1,rider-v1
NEXT_PUBLIC_ARENA_MARKET_ID=1        # must match ARENA_MARKET_ID (market 0 wedged)
NEXT_PUBLIC_ARENA_CLUSTER_LABEL=devnet

# Flash v2 migration (MagicBlock Ephemeral Rollup execution)
# FEATURE_FLASH_V2 (server) and NEXT_PUBLIC_FEATURE_FLASH_V2 (client) MUST match;
# 'true' routes supported execution to the v2 rails, anything else stays on v1.
FEATURE_FLASH_V2=
NEXT_PUBLIC_FEATURE_FLASH_V2=
# Client-side ER RPC for broadcasting user-signed self-directed v2 trades. A
# public MagicBlock URL; falls back to NEXT_PUBLIC_ARENA_ER_ENDPOINT then mainnet.
NEXT_PUBLIC_FLASH_V2_ER_RPC=

# Pyth Lazer access token — powers the ~20ms scalp price feed via the server-side
# relay at /api/flash/perp/prices/lazer (token never reaches the browser). When
# unset the relay returns 503 and the scalp feed falls back to Pyth Hermes (~2-4/s).
# Get one at https://pyth.network/lazer.
LAZER_TOKEN=

# Web Push / VAPID (Task 12)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY: safe to expose in the browser.
# Run `npx web-push generate-vapid-keys --json` to generate a key pair.
# The public key shown here is the real prod public key (sharing it is fine).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BCT79F-HYsq81MMn2aHNILDiMdyrVhygmrRrYfPvUy22j5lQom9Jl7Z-mINSOKZmXTVJZe1iT2lzbnAT4Y5tRBE
# NEVER commit the real private key. Keep in .env.local / Railway secrets only.
VAPID_PRIVATE_KEY=<your-vapid-private-key-here>
VAPID_SUBJECT=mailto:ops@gwak.gg

# LLM oracle bots (Claude + Grok + GPT + Vader) — off-chain brain →
# operator-signed apply_decision. Roster lives in lib/arena/llm/registry.ts.
ANTHROPIC_API_KEY=                   # Claude + Vader decision model (@ai-sdk/anthropic)
XAI_API_KEY=                         # Grok decision model (@ai-sdk/xai) + sentiment oracle
OPENAI_API_KEY=                      # GPT decision model (@ai-sdk/openai)
DISABLE_ARENA_LLM=                   # "true" disables the brain loop entirely
ARENA_BASE_RPC=https://api.devnet.solana.com   # base-layer RPC for init/delegate
ARENA_ER_VALIDATOR=                  # ER validator identity to pin on delegate_llm_bot
ARENA_START_BALANCE_MICRO=1000000000 # starting paper balance ($1,000)
# Devnet: market 0 was wedged (2026-06-12 undelegation); use market 1.
# ARENA_MARKET_ID + NEXT_PUBLIC_ARENA_MARKET_ID must match (see above).
ARENA_MARKET_ID=1
# Operator secret keys (JSON arrays) — the ONLY keys that can drive each bot's
# decisions. Fall back to ARENA_LLM_OPERATOR (one shared operator) if per-bot unset.
ARENA_LLM_OPERATOR_CLAUDE=
ARENA_LLM_OPERATOR_GROK=
ARENA_LLM_OPERATOR_GPT=
ARENA_LLM_OPERATOR_VADER=
ARENA_LLM_OPERATOR=
